# Fashion Instagram Caption Generator
# Environment Variables Template
# 
# HOW TO USE:
# 1. Copy this file to .env (same directory as caption_generator.py and app.py)
# 2. Replace YOUR_API_KEY_HERE with your actual Anthropic API key
# 3. Make sure .env is in your .gitignore
# 4. DO NOT commit this file to GitHub

# Your Anthropic API Key
# Get it from: https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=YOUR_API_KEY_HERE

# Optional: Flask configuration (for web app)
# FLASK_ENV=development
# FLASK_DEBUG=True
